# ===== App =====
DEBUG=true
APP_NAME=PubliSync

# ===== Database =====
DATABASE_URL=postgresql+asyncpg://publisync:publisync@localhost:5432/publisync
POSTGRES_PASSWORD=publisync
DB_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== JWT =====
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== OAuth Token Encryption (Fernet) =====
OAUTH_ENCRYPTION_KEY=change-me-use-python-cryptography-fernet-generate-key

# ===== MinIO =====
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=publisync-media
MINIO_SECURE=false

# ===== Email (SMTP) =====
MAIL_FROM=noreply@publisync.kr
MAIL_SERVER=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_TLS=true
MAIL_SSL=false

# ===== CORS =====
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ===== Celery =====
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ===== Meilisearch =====
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=publisync_meili_key

# ===== Sentry =====
SENTRY_DSN=

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=

# ===== AI (litellm) =====
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AI_DEFAULT_MODEL=gpt-4o-mini
AI_FALLBACK_MODELS=["claude-sonnet-4-6","gemini-1.5-flash"]
AI_MAX_TOKENS=2000
AI_TIMEOUT=30

# ===== Web Push (VAPID) =====
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=admin@publisync.kr
