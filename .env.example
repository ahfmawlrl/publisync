# ==============================================================================
# PubliSync Environment Variables
# 복사: cp .env.example .env  →  각 섹션의 값을 채워넣으세요
# ==============================================================================

# ===== App =====
DEBUG=true
APP_NAME=PubliSync

# ===== Database =====
# Docker 내부: postgres:5432 / 로컬 직접 실행: localhost:5432
DATABASE_URL=postgresql+asyncpg://publisync:publisync@localhost:5432/publisync
POSTGRES_PASSWORD=publisync
DB_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ===== Redis =====
# Docker 내부: redis:6379 / 로컬 직접 실행: localhost:6379
REDIS_URL=redis://localhost:6379/0

# ===== JWT =====
# 생성: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== OAuth Token Encryption (Fernet) =====
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OAUTH_ENCRYPTION_KEY=change-me-use-python-cryptography-fernet-generate-key

# ===== MinIO =====
# Docker 내부: minio:9000 / 로컬 직접 실행: localhost:9000
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=publisync-media
MINIO_SECURE=false

# ===== Email (SMTP) =====
# Gmail: smtp.gmail.com:587 / Naver: smtp.naver.com:587
MAIL_FROM=noreply@publisync.kr
MAIL_SERVER=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_TLS=true
MAIL_SSL=false

# ===== CORS =====
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ===== Celery =====
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ===== Meilisearch =====
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=publisync_meili_key

# ==============================================================================
# B. 외부 연동 (API 키 발급 필요)
# ==============================================================================

# ── B-1. YouTube (Google Cloud Console) ──────────────────
# 발급: https://console.cloud.google.com → API 및 서비스 → 사용자 인증 정보
# 필요 API: YouTube Data API v3
# OAuth 동의 화면 → 리디렉션 URI: http://localhost:5173/channels/callback/youtube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ── B-2. Instagram + Facebook (Meta Developer) ──────────
# 발급: https://developers.facebook.com → 앱 만들기
# 필요 권한: instagram_basic, instagram_content_publish, pages_manage_posts
# 리디렉션 URI: http://localhost:5173/channels/callback/instagram
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_APP_ID=1483012306867432
INSTAGRAM_APP_SECRET=xxxx
INSTAGRAM_ACCESS_TOKEN=xxxx

# ── B-3. X / Twitter (X Developer Portal) ───────────────
# 발급: https://developer.x.com → Projects & Apps
# OAuth 2.0 설정, 리디렉션 URI: http://localhost:5173/channels/callback/x
X_CLIENT_ID=
X_CLIENT_SECRET=

# ── B-4. Naver Blog (Naver Developers) ──────────────────
# 발급: https://developers.naver.com → 애플리케이션 등록
# 필요 API: 블로그, 네이버 로그인
# 리디렉션 URI: http://localhost:5173/channels/callback/naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── B-5. OAuth Redirect Base URL ─────────────────────────
# 프론트엔드 콜백 URL 베이스 (개발: localhost:5173)
OAUTH_REDIRECT_BASE_URL=http://localhost:5173/channels/callback

# ── B-6. AI API Keys (하나 이상 필수) ─────────────────────
# OpenAI:    https://platform.openai.com/api-keys
# Anthropic: https://console.anthropic.com/settings/keys
# Google:    https://aistudio.google.com/apikey
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AI_DEFAULT_MODEL=gpt-4o-mini
AI_FALLBACK_MODELS=["claude-sonnet-4-6","gemini-1.5-flash"]
AI_MAX_TOKENS=2000
AI_TIMEOUT=30

# ── B-7. Telegram Bot ────────────────────────────────────
# 발급: Telegram @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# ── B-8. Sentry (에러 모니터링) ───────────────────────────
# 발급: https://sentry.io → 프로젝트 생성 → DSN 복사
SENTRY_DSN=

# ── B-9. Web Push (VAPID) ────────────────────────────────
# 생성: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=admin@publisync.kr

# ===== Monitoring =====
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production
